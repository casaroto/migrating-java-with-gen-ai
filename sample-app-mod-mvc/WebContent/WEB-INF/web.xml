<login-config>
    <auth-method>FORM</auth-method>
    <realm-name>Form Authentication Realm</realm-name>
    <form-login-config>
        <form-login-page>/login.jsp</form-login-page>
        <form-error-page>/login.jsp</form-error-page>
    </form-login-config>
</login-config>

<security-role>
    <role-name>users</role-name>
</security-role>

</web-app>
